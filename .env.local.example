# Local development environment variables
# Copy to `.env.local` and adjust as needed.

# Local MySQL via docker-compose.yml
DATABASE_URL="mysql://root:brochify@localhost:3306/brochify"

# Session signing secret for auth cookies
SESSION_SECRET="replace_with_secure_random_value"

# Optional seed overrides (used when DB is empty)
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="admin123"
# SEED_FACULTY_USERNAME="faculty"
# SEED_FACULTY_PASSWORD="faculty123"

# Optional external service keys
# OPENROUTER_API_KEY=""
# NEXT_PUBLIC_FAL_API_KEY=""
