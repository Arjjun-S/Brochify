generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int             @id @default(autoincrement())
  username             String          @unique @db.VarChar(64)
  password             String?         @db.VarChar(255)
  passwordHash         String?         @map("password_hash") @db.VarChar(255)
  role                 UserRole
  createdAt            DateTime        @default(now()) @map("created_at")
  assignedBrochures    Brochure[]      @relation("BrochureAssignee")
  createdBrochures     Brochure[]      @relation("BrochureCreator")
  assignedCertificates Certificate[]   @relation("CertificateAssignee")
  createdCertificates  Certificate[]   @relation("CertificateCreator")
  designProjects       DesignProject[] @relation("DesignProjectCreator")

  @@map("users")
}

model Brochure {
  id                Int            @id @default(autoincrement())
  title             String         @db.VarChar(255)
  description       String         @db.Text
  content           Json
  createdBy         Int            @map("created_by")
  assignedAdminId   Int            @map("assigned_admin")
  status            ReviewStatus   @default(draft)
  rejectionReason   String?        @map("rejection_reason") @db.Text
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  assignedAdminUser User           @relation("BrochureAssignee", fields: [assignedAdminId], references: [id], onDelete: Cascade)
  creator           User           @relation("BrochureCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  designProject     DesignProject? @relation("BrochureDesignProject")

  @@index([status])
  @@index([createdBy])
  @@index([assignedAdminId])
  @@map("brochures")
}

model Certificate {
  id                Int                       @id @default(autoincrement())
  title             String                    @db.VarChar(255)
  description       String                    @db.Text
  content           Json
  createdBy         Int                       @map("created_by")
  assignedAdminId   Int                       @map("assigned_admin")
  status            ReviewStatus              @default(draft)
  rejectionReason   String?                   @map("rejection_reason") @db.Text
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")
  verifications     CertificateVerification[]
  assignedAdminUser User                      @relation("CertificateAssignee", fields: [assignedAdminId], references: [id], onDelete: Cascade)
  creator           User                      @relation("CertificateCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdBy])
  @@index([assignedAdminId])
  @@map("certificates")
}

model Asset {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(255)
  type               String   @db.VarChar(50)
  cloudinaryUrl      String   @map("cloudinary_url") @db.VarChar(512)
  cloudinaryPublicId String   @map("cloudinary_public_id") @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([type])
  @@map("assets")
}

model DesignProject {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  json         String    @db.LongText
  width        Int       @default(900)
  height       Int       @default(1200)
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(512)
  isTemplate   Boolean   @default(false) @map("is_template")
  isPro        Boolean   @default(false) @map("is_pro")
  brochureId   Int?      @unique @map("brochure_id")
  createdBy    Int       @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  brochure     Brochure? @relation("BrochureDesignProject", fields: [brochureId], references: [id])
  creator      User      @relation("DesignProjectCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([isTemplate])
  @@map("design_projects")
}

model CertificateVerification {
  id                Int         @id @default(autoincrement())
  certificateId     Int         @map("certificate_id")
  recipientName     String      @map("recipient_name") @db.VarChar(255)
  verificationToken String      @unique @map("verification_token") @db.VarChar(64)
  generatedAt       DateTime    @default(now()) @map("generated_at")
  organization      String?     @db.VarChar(255)
  certificate       Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([certificateId])
  @@map("certificate_verifications")
}

enum UserRole {
  admin
  faculty
}

enum ReviewStatus {
  draft
  pending
  approved
  rejected
}
